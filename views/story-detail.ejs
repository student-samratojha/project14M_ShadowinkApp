<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= story?.title ? story.title + ' - ShadowInk' : 'Story Detail - ShadowInk' %></title>

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Google Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    :root{
      --dark:#050505;
      --card:#0f0f0f;
      --yellow:#facc15;
      --line:#2b2b2b;
      --glow:rgba(250,204,21,.25);
    }

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family:'Inter',sans-serif;
      background:
      linear-gradient(rgba(0,0,0,.88),rgba(0,0,0,.95)),
      url('https://images.unsplash.com/photo-1519608487953-e999c86e7455?q=80&w=2070&auto=format&fit=crop');
      background-size:cover;
      background-position:center;
      background-attachment:fixed;
      color:white;
      overflow-x:hidden;
      min-height:100vh;
      position:relative;
    }

    body::before{
      content:'';
      position:fixed;
      inset:0;
      background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size:60px 60px;
      animation:gridMove 10s linear infinite;
      z-index:-1;
    }

    @keyframes gridMove{
      0%{ transform:translateY(0px); }
      100%{ transform:translateY(60px); }
    }

    .lightning{
      position:fixed;
      inset:0;
      pointer-events:none;
      z-index:50;
      animation:flash 8s infinite;
    }

    @keyframes flash{
      0%,95%,100%{ opacity:0; }
      96%{ opacity:.08; background:white; }
      97%{ opacity:0; }
      98%{ opacity:.18; background:#9ecbff; }
    }

    .nav-blur{
      background:rgba(0,0,0,.75);
      backdrop-filter:blur(12px);
      border-bottom:1px solid rgba(250,204,21,.15);
    }

    .bat-logo{
      width:65px;
      height:28px;
      background:var(--yellow);
      clip-path: polygon(
      0% 50%, 10% 30%, 20% 40%, 30% 10%, 40% 35%,
      50% 0%, 60% 35%, 70% 10%, 80% 40%, 90% 30%, 100% 50%,
      85% 70%, 70% 60%, 60% 100%, 50% 70%, 40% 100%, 30% 60%, 15% 70%
      );
      filter:drop-shadow(0 0 8px rgba(250,204,21,.35));
      animation:logoFloat 7s ease-in-out infinite;
    }

    @keyframes logoFloat{
      0%,100%{ transform:translateY(0px) scale(1); }
      50%{ transform:translateY(-4px) scale(1.02); }
    }

    .hero-title{
      font-family:'Orbitron',sans-serif;
      font-size:clamp(2rem,4vw,3rem);
      font-weight:700;
      line-height:1.05;
      text-transform:uppercase;
      letter-spacing:2px;
      animation:float 7s ease-in-out infinite;
      text-shadow:
      0 0 6px rgba(250,204,21,.15),
      0 0 18px rgba(250,204,21,.08);
    }

    @keyframes float{
      0%,100%{ transform:translateY(0px); }
      50%{ transform:translateY(-12px); }
    }

    .story-card{
      background:rgba(15,15,15,.92);
      border:1px solid rgba(255,255,255,.06);
      border-radius:24px;
      overflow:hidden;
      position:relative;
      transform-style:preserve-3d;
      transition:all .5s ease;
      backdrop-filter:blur(12px);
    }

    .story-card::before{
      content:'';
      position:absolute;
      inset:0;
      background:linear-gradient(
      130deg,
      transparent,
      rgba(250,204,21,.08),
      transparent
      );
      transform:translateX(-100%);
      transition:1s;
    }

    .story-card:hover::before{
      transform:translateX(100%);
    }

    .story-card:hover{
      transform:
      perspective(1000px)
      rotateX(6deg)
      rotateY(-6deg)
      translateY(-12px);
      border-color:rgba(250,204,21,.4);
      box-shadow:
      0 0 25px rgba(250,204,21,.15),
      0 20px 40px rgba(0,0,0,.55);
    }

    .yellow-line{
      width:80px;
      height:3px;
      background:var(--yellow);
      margin-top:15px;
      border-radius:20px;
      box-shadow:0 0 20px rgba(250,204,21,.8);
      animation:lineMove 2s infinite alternate;
    }

    @keyframes lineMove{
      0%{ width:80px; }
      100%{ width:140px; }
    }

    .bat-btn{
      background:var(--yellow);
      color:black;
      font-weight:700;
      padding:14px 26px;
      border-radius:14px;
      transition:.4s;
      box-shadow:0 0 18px rgba(250,204,21,.25);
    }

    .bat-btn:hover{
      transform:translateY(-3px);
      box-shadow:0 0 35px rgba(250,204,21,.45);
    }

    .yellow-glow{
      color:var(--yellow);
      text-shadow:0 0 15px rgba(250,204,21,.4);
    }

    .smooth{
      transition:.4s ease;
    }

    .detail-banner{
      min-height:380px;
      background-size:cover;
      background-position:center;
      position:relative;
      overflow:hidden;
      border-radius:28px;
    }

    .detail-banner::after{
      content:'';
      position:absolute;
      inset:0;
      background:linear-gradient(180deg,rgba(0,0,0,0) 20%,rgba(0,0,0,.92) 100%);
    }

    .detail-header{
      position:absolute;
      bottom:28px;
      left:28px;
      right:28px;
      z-index:2;
    }

    .detail-pill{
      display:inline-flex;
      align-items:center;
      gap:.5rem;
      padding:.55rem 1rem;
      background:rgba(0,0,0,.55);
      border:1px solid rgba(250,204,21,.18);
      border-radius:999px;
      color:#d1d5db;
      font-size:.85rem;
      letter-spacing:.15em;
      text-transform:uppercase;
    }

    .detail-meta{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:1rem;
    }

    .detail-meta span{
      display:flex;
      flex-direction:column;
      gap:.25rem;
      color:#cbd5e1;
      font-size:.95rem;
    }

    .detail-meta strong{
      color:white;
      font-size:1rem;
    }

    .story-content p{
      margin-bottom:1.55rem;
      line-height:1.85;
      color:#d1d5db;
    }

    .story-content blockquote{
      border-left:4px solid rgba(250,204,21,.5);
      padding-left:1rem;
      color:#f8fafc;
      font-size:1.05rem;
      font-style:italic;
      margin:1.7rem 0;
      opacity:.95;
    }

  </style>
</head>

<body>
  <div class="lightning"></div>
  <% const bannerImage = story.bannerImage || 'https://images.unsplash.com/photo-1519608487953-e999c86e7455?q=80&w=2070&auto=format&fit=crop';
     const authorName = story.author && story.author.name ? story.author.name : 'Unknown Author';
     const createdDate = story.createdAt ? new Date(story.createdAt).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) : 'Unknown';
     const likeCount = story.likes && story.likes.length ? story.likes.length : 0;
     const dislikeCount = story.dislikes && story.dislikes.length ? story.dislikes.length : 0;
  %>

  <nav class="nav-blur sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-6 py-5 flex justify-between items-center">
      <div class="flex items-center gap-4">
        <div class="bat-logo"></div>
        <div>
          <h1 class="text-xl font-semibold tracking-[2px] yellow-glow uppercase">ShadowInk</h1>
          <p class="text-[10px] tracking-[2px] text-gray-500 uppercase">archive access</p>
        </div>
      </div>
      <div class="hidden md:flex items-center gap-10 text-sm uppercase tracking-[2px] font-semibold">
        <a href="/" class="hover:text-yellow-400 smooth">Dashboard</a>
        <a href="/story/all" class="hover:text-yellow-400 smooth">Stories</a>
        <a href="/story/create" class="hover:text-yellow-400 smooth">Write</a>
        <a href="/auth/logout" class="hover:text-yellow-400 smooth">Logout</a>
      </div>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-6 py-10 space-y-10">
    <section class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] items-start">
      <div class="space-y-6">
        <div class="detail-banner story-card" style="background-image:url('<%= bannerImage %>')">
          <div class="detail-header">
            <div class="detail-pill">Story Detail</div>
            <h1 class="text-3xl sm:text-4xl font-semibold tracking-[1px]"><%= story.title || 'Untitled Shadow Tale' %></h1>
            <div class="detail-meta mt-6">
              <span>
                <strong><%= authorName %></strong>
                Author
              </span>
              <span>
                <strong><%= createdDate %></strong>
                Released
              </span>
              <span>
                <strong><%= likeCount %> Likes</strong>
                Applause
              </span>
            </div>
          </div>
        </div>

        <div class="story-card p-8 space-y-6">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="text-[11px] uppercase tracking-[2px] text-gray-500">Encrypted narrative</p>
              <h2 class="text-2xl font-semibold text-white">Secure story detail</h2>
            </div>
            <a href="/story/all" class="bat-btn">Back to Archive</a>
          </div>

          <div class="story-content prose prose-invert max-w-none">
            <% if (story.content) { %>
              <% story.content.split('\n').forEach(function(paragraph) { %>
                <p><%= paragraph %></p>
              <% }); %>
            <% } else { %>
              <p>The story content is not available at the moment. Return to the archive or create a new legend.</p>
            <% } %>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-3xl border border-yellow-500/10 p-5 bg-black/50">
              <h3 class="text-yellow-400 uppercase tracking-[2px] text-sm">Story ID</h3>
              <p class="mt-3 text-white text-sm break-all"><%= story._id %></p>
            </div>
            <div class="rounded-3xl border border-yellow-500/10 p-5 bg-black/50">
              <h3 class="text-yellow-400 uppercase tracking-[2px] text-sm">Mood</h3>
              <p class="mt-3 text-white text-sm">Dark, cinematic, charged</p>
            </div>
          </div>
        </div>
      </div>

      <aside class="space-y-6">
        <div class="story-card p-8 space-y-5">
          <p class="text-sm uppercase tracking-[3px] text-gray-400">Story Stats</p>
          <div class="grid gap-4">
            <div class="rounded-3xl border border-yellow-500/10 p-5 bg-black/50">
              <p class="text-gray-300">Likes</p>
              <p class="text-2xl font-semibold text-white"><%= story.likes && story.likes.length ? story.likes.length : 0 %></p>
            </div>
            <div class="rounded-3xl border border-yellow-500/10 p-5 bg-black/50">
              <p class="text-gray-300">Dislikes</p>
              <p class="text-2xl font-semibold text-white"><%= story.dislikes && story.dislikes.length ? story.dislikes.length : 0 %></p>
            </div>
            <div class="rounded-3xl border border-yellow-500/10 p-5 bg-black/50">
              <p class="text-gray-300">Status</p>
              <p class="text-2xl font-semibold text-white">Encrypted</p>
            </div>
          </div>
        </div>

        <div class="story-card p-8 bg-gradient-to-br from-zinc-900/90 to-black/80 border border-yellow-500/10">
          <h3 class="text-xl font-semibold yellow-glow">Shadow Ink Access</h3>
          <p class="mt-4 text-gray-300 leading-7">Every hero and villain needs an archive. This page displays the selected story with glowing detail and a cinematic reading experience.</p>
          <a href="/story/create" class="bat-btn inline-flex">Write Your Next Chapter</a>
        </div>
      </aside>
    </section>
  </main>
</body>
</html>
