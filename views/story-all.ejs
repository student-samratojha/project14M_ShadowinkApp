<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'All Stories - ShadowInk' %></title>

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Google Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    :root{
      --dark:#050505;
      --card:#0f0f0f;
      --yellow:#facc15;
      --line:#2b2b2b;
      --glow:rgba(250,204,21,.25);
    }

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family:'Inter',sans-serif;
      background:
      linear-gradient(rgba(0,0,0,.88),rgba(0,0,0,.95)),
      url('https://images.unsplash.com/photo-1519608487953-e999c86e7455?q=80&w=2070&auto=format&fit=crop');
      background-size:cover;
      background-position:center;
      background-attachment:fixed;
      color:white;
      overflow-x:hidden;
      min-height:100vh;
      position:relative;
    }

    /* MOVING LINES */
    body::before{
      content:'';
      position:fixed;
      inset:0;
      background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size:60px 60px;
      animation:gridMove 10s linear infinite;
      z-index:-1;
    }

    @keyframes gridMove{
      0%{
        transform:translateY(0px);
      }
      100%{
        transform:translateY(60px);
      }
    }

    /* LIGHTNING */
    .lightning{
      position:fixed;
      inset:0;
      pointer-events:none;
      z-index:50;
      animation:flash 8s infinite;
    }

    @keyframes flash{
      0%,95%,100%{
        opacity:0;
      }
      96%{
        opacity:.08;
        background:white;
      }
      97%{
        opacity:0;
      }
      98%{
        opacity:.18;
        background:#9ecbff;
      }
    }

    /* NAV */
    .nav-blur{
      background:rgba(0,0,0,.75);
      backdrop-filter:blur(12px);
      border-bottom:1px solid rgba(250,204,21,.15);
    }

    /* LOGO */
    .bat-logo{
      width:65px;
      height:28px;
      background:var(--yellow);
      clip-path: polygon(
      0% 50%, 10% 30%, 20% 40%, 30% 10%, 40% 35%,
      50% 0%, 60% 35%, 70% 10%, 80% 40%, 90% 30%, 100% 50%,
      85% 70%, 70% 60%, 60% 100%, 50% 70%, 40% 100%, 30% 60%, 15% 70%
      );
      filter:drop-shadow(0 0 8px rgba(250,204,21,.35));
      animation:logoFloat 7s ease-in-out infinite;
    }

    @keyframes logoFloat{
      0%,100%{
        transform:translateY(0px) scale(1);
      }
      50%{
        transform:translateY(-4px) scale(1.02);
      }
    }

    /* HERO TITLE */
    .hero-title{
      font-family:'Orbitron',sans-serif;
      font-size:clamp(3rem,7vw,6rem);
      font-weight:900;
      line-height:1;
      text-transform:uppercase;
      letter-spacing:3px;
      animation:float 4s ease-in-out infinite;
      text-shadow:
      0 0 10px rgba(250,204,21,.2),
      0 0 30px rgba(250,204,21,.1);
    }

    @keyframes float{
      0%,100%{
        transform:translateY(0px);
      }
      50%{
        transform:translateY(-12px);
      }
    }

    /* CARD */
    .story-card{
      background:rgba(15,15,15,.9);
      border:1px solid rgba(255,255,255,.05);
      border-radius:20px;
      overflow:hidden;
      position:relative;
      transform-style:preserve-3d;
      transition:all .5s ease;
      backdrop-filter:blur(10px);
    }

    .story-card::before{
      content:'';
      position:absolute;
      inset:0;
      background:linear-gradient(
      130deg,
      transparent,
      rgba(250,204,21,.08),
      transparent
      );
      transform:translateX(-100%);
      transition:1s;
    }

    .story-card:hover::before{
      transform:translateX(100%);
    }

    .story-card:hover{
      transform:
      perspective(1000px)
      rotateX(6deg)
      rotateY(-6deg)
      translateY(-12px);

      border-color:rgba(250,204,21,.4);

      box-shadow:
      0 0 25px rgba(250,204,21,.15),
      0 20px 40px rgba(0,0,0,.5);
    }

    .yellow-line{
      width:80px;
      height:3px;
      background:var(--yellow);
      margin-top:15px;
      border-radius:20px;
      box-shadow:0 0 20px rgba(250,204,21,.8);
      animation:lineMove 2s infinite alternate;
    }

    @keyframes lineMove{
      0%{
        width:80px;
      }
      100%{
        width:140px;
      }
    }

    /* BUTTON */
    .bat-btn{
      background:var(--yellow);
      color:black;
      font-weight:700;
      padding:12px 24px;
      border-radius:12px;
      transition:.4s;
      box-shadow:0 0 15px rgba(250,204,21,.2);
    }

    .bat-btn:hover{
      transform:translateY(-4px);
      box-shadow:0 0 30px rgba(250,204,21,.4);
    }

    /* TEXT GLOW */
    .yellow-glow{
      color:var(--yellow);
      text-shadow:0 0 15px rgba(250,204,21,.4);
    }

    /* SMOOTH */
    .smooth{
      transition:.4s ease;
    }

  </style>
</head>
<body>

  <!-- LIGHTNING -->
  <div class="lightning"></div>

  <style>

    body{
      font-family:'Inter',sans-serif;

      background:
      linear-gradient(rgba(0,0,0,.82),rgba(0,0,0,.92)),
      url('https://images.unsplash.com/photo-1506744038136-46273834b3fb?q=80&w=2400&auto=format&fit=crop');

      background-size:cover;
      background-position:center;
      background-attachment:fixed;

      color:white;
      overflow-x:hidden;
      min-height:100vh;
      position:relative;
    }

    .top-bar{
      background:rgba(0,0,0,.55);
      backdrop-filter:blur(12px);
      border-bottom:1px solid rgba(250,204,21,.12);
    }

    .bat-btn{
      background:#facc15;
      color:black;
      font-weight:700;
      padding:12px 24px;
      border-radius:14px;
      transition:.4s;
      box-shadow:0 0 20px rgba(250,204,21,.2);
    }

    .bat-btn:hover{
      transform:translateY(-4px);
      box-shadow:0 0 35px rgba(250,204,21,.45);
    }

    .glass-btn{
      border:1px solid rgba(255,255,255,.1);
      background:rgba(255,255,255,.05);
      backdrop-filter:blur(10px);
      transition:.4s;
    }

    .glass-btn:hover{
      border-color:rgba(250,204,21,.4);
      background:rgba(250,204,21,.08);
    }

    .story-card{
      background:rgba(10,10,10,.78);
      border:1px solid rgba(255,255,255,.05);
      border-radius:24px;
      overflow:hidden;
      position:relative;
      transition:.45s ease;
      backdrop-filter:blur(14px);
    }

    .story-card:hover{
      transform:
      perspective(1000px)
      rotateX(5deg)
      rotateY(-5deg)
      translateY(-10px);

      border-color:rgba(250,204,21,.3);

      box-shadow:
      0 0 30px rgba(250,204,21,.15),
      0 20px 50px rgba(0,0,0,.55);
    }

    .story-card::before{
      content:'';
      position:absolute;
      inset:0;

      background:
      linear-gradient(
      130deg,
      transparent,
      rgba(250,204,21,.08),
      transparent
      );

      transform:translateX(-100%);
      transition:1s;
    }

    .story-card:hover::before{
      transform:translateX(100%);
    }

    .yellow-glow{
      color:#facc15;
      text-shadow:0 0 18px rgba(250,204,21,.4);
    }

    .smooth{
      transition:.4s ease;
    }

  </style>

  <!-- TOP BAR -->
  <nav class="top-bar sticky top-0 z-50">

    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-5 flex items-center justify-between">

      <div>

        <h1 class="text-xl sm:text-2xl font-semibold tracking-[2px] uppercase yellow-glow">
          ShadowInk
        </h1>

        <p class="text-[10px] tracking-[2px] text-gray-500 uppercase mt-1">
          dark archive
        </p>

      </div>

      <div class="flex items-center gap-3">

        <a
          href="/"
          class="glass-btn px-5 py-3 rounded-xl text-sm uppercase tracking-[2px]"
        >
          Dashboard
        </a>

        <a
          href="/auth/logout"
          class="bat-btn text-sm uppercase tracking-[2px]"
        >
          Logout
        </a>

      </div>

    </div>

  </nav>

  <!-- STORIES -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-10 sm:py-14">

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">

      <% if(typeof stories !== 'undefined' && stories.length > 0){ %>

        <% stories.forEach(item => { %>

          <div class="story-card p-7 group">

            <img
              src="<%= item.bannerImage %>"
              alt="story-banner"
              class="w-full h-52 object-cover rounded-2xl mb-6 border border-white/5"
            >

            <div class="flex items-start justify-between gap-3 mb-4">

              <h2 class="text-xl font-semibold text-yellow-300 group-hover:text-yellow-300 smooth">
                <%= item.title %>
              </h2>

              <span class="text-[10px] uppercase tracking-[2px] text-gray-600">
                secure
              </span>

            </div>

            <p class="text-gray-400 leading-7 text-sm">
              <%= item.content.substring(0, 120) %>...
            </p>

            <div class="mt-7 flex items-center justify-between">

              <span class="text-xs text-gray-600 uppercase tracking-[2px]">
                <%= item.author?.name || 'Anonymous' %>
              </span>

              <a
                href="/story/<%= item._id %>"
                class="text-yellow-400 hover:text-yellow-300 smooth text-sm font-semibold"
              >
                Read →
              </a>

            </div>

          </div>

        <% }) %>

      <% } else { %>

        <div class="story-card p-12 text-center col-span-full">

          <h2 class="text-2xl font-semibold yellow-glow mb-4 uppercase tracking-[3px]">
            No Stories
          </h2>

          <p class="text-gray-500 mb-8">
            The vault is empty.
          </p>

          <a
            href="/story/create"
            class="bat-btn inline-block"
          >
            Write Story
          </a>

        </div>

      <% } %>

    </div>

  </main>

  <!-- FOOTER -->
  <footer class="border-t border-white/5 mt-10">

    <div class="max-w-7xl mx-auto px-6 py-8 text-center">

      <p class="text-gray-700 text-xs tracking-[4px] uppercase">
        © 2026 ShadowInk Systems
      </p>

    </div>

  </footer>

</body>
</html>